<p style="color: green"><%= notice %></p>
<div>
  <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
    <div class="sm:flex sm:items-center">
      <div class="sm:flex-auto">
        <h1 class="text-base font-semibold leading-6 text-gray-900">Devices & Sessions</h1>
        <p class="mt-2 text-sm text-gray-700">A list of all the devices signed into your account.</p>
      </div>
    </div>
    <div class="mt-8 flow-root overflow-hidden">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <table class="w-full text-left">
          <thead class="bg-white">
            <tr>
              <th scope="col" class="relative isolate py-3.5 pr-3 text-left text-sm font-semibold text-gray-900">
                User Agent
                <div class="absolute inset-y-0 right-full -z-10 w-screen border-b border-b-gray-200"></div>
                <div class="absolute inset-y-0 left-0 -z-10 w-screen border-b border-b-gray-200"></div>
              </th>
              <th scope="col" class="hidden px-3 py-3.5 text-left text-sm font-semibold text-gray-900 md:table-cell">Ip Address</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Created at</th>
              <th scope="col" class="relative py-3.5 pl-3">
                <span class="sr-only">Edit</span>
              </th>
            </tr>
          </thead>
          <tbody>
            <% @sessions.each do |session| %>
              <tr>
                <td class="relative py-4 pr-3 text-sm font-medium text-gray-900">
                  <%= session.user_agent %>
                  <div class="absolute bottom-0 right-full h-px w-screen bg-gray-100"></div>
                  <div class="absolute bottom-0 left-0 h-px w-screen bg-gray-100"></div>
                </td>
                <td class="hidden px-3 py-4 text-sm text-gray-500 sm:table-cell">
                  <%= session.ip_address %>
                </td>
                <td class="hidden px-3 py-4 text-sm text-gray-500 md:table-cell">
                  <%= session.created_at %>
                </td>
                <td class="relative py-4 pl-3 text-right text-sm font-medium">
                  <%= button_to "Log out", session, method: :delete, class: "text-indigo-600 hover:text-indigo-900" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="mt-6 flex items-center justify-end gap-x-6">
        <%= link_to "Back", account_path, class: "text-sm font-semibold leading-6 text-gray-900" %>
      </div>
    </div>
  </div>
</div>
